# serry-voiceassistant - Environment Variables (fully local / MLX stack)
# Copy this file to .env. Local models need no API keys.

# --- Identity ---
# The assistant's name (full + spoken short form) and the user it serves.
# Used in the system prompt, ASR vocabulary, and the default wake words.
AGENT_NAME=Serrynaimo
AGENT_NAME_SHORT=Serry
USER_NAME=John Doe
USER_NAME_SHORT=John

# --- Transport ---
# SmallWebRTC (default local transport) needs no key.
# Daily is optional; only set this if you switch the transport to Daily.
# DAILY_API_KEY=
# Bind address of the web server (0.0.0.0 = reachable from the LAN).
# RUNNER_HOST=0.0.0.0

# --- LLM ---
# Default brain: LM Studio (OpenAI-compatible local server) — a text-only
# model that reads the ASR transcript. LLM_AUDIO_INPUT=omni below swaps in
# the audio-native Qwen3-Omni brain, run BY the bot via llama.cpp, which
# hears your actual voice instead:
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio
# Leave empty to auto-use whatever model is loaded in LM Studio
LMSTUDIO_MODEL=
# Reasoning suppression for thinking models (gpt-oss etc.): none/minimal/low/medium/high
LMSTUDIO_REASONING_EFFORT=none
# Renice LM Studio down at bot start so the voice pipeline wins CPU contention (1=on)
LMSTUDIO_DEPRIORITIZE=1

# --- Prompt-cache friendliness (keeps turn latency ~constant) ---
# Eager: connect MCP servers at session start so the tools array never
# changes mid-conversation. Keys: calendar, reminders, contacts, notes.
# (Email is native — always available, never an MCP toolset.) "" = all lazy,
# "all" = all eager, or a comma list (loaded up front; the rest load on demand).
# Append-only: memory injections never rewrite earlier context messages. Both
# matter for LM Studio's KV cache, especially with hybrid models like
# qwen3-coder-next (needs mlx-engine >= 1.8.5).
MCP_EAGER_TOOLSETS=calendar
MEMORY_INJECT_APPEND_ONLY=1
# Context compression: past this many conversation tokens (message chars/4;
# tools + template overhead NOT counted), older turns are summarized and the
# bot voices a short "refocusing" line while it happens. "auto" senses the
# loaded model's context window from LM Studio and subtracts a 16k reserve;
# "off" disables compression (LM Studio then truncates per its own overflow
# policy). Lower explicit values = shorter compression stalls (~2k tok/s).
CONTEXT_MAX_TOKENS=auto
# Tool chains busy longer than this get cancelled and the model is nudged
# (hidden user message: "This takes too long, try something else"). 0 = off.
TOOL_STALL_NUDGE_SECS=60

# --- Client behavior ---
# Filler clip ("Just a second.") plays when the bot's voice hasn't arrived
# this many seconds after a submitted turn; repeats ~15s while tools run.
FILLER_DELAY_SECS=3

# --- Long-term memory ---
# Facts from remember/recall live in Apple Notes, in a folder named after
# AGENT_NAME (created on first use). A notes_memory.db sidecar next to bot.py
# holds recall stats only. Nothing to configure here.

# Which brain, and whether it hears you. One switch, three states:
#   0    = (default) LM Studio (above) is the brain; it only reads the ASR
#          transcript. A big model there is a noticeably stronger reasoner
#          and tool user than the 30B-A3B omni, but deaf to tone.
#   omni = run the audio-native model as part of the bot: llama.cpp's
#          llama-server with Qwen3-Omni starts at bot startup and is the
#          LLM — it HEARS the gated utterance audio (tone included), not
#          just the ASR transcript. ASR still runs (speaker/wake gates,
#          live captions, searchable transcript) and Qwen3-TTS still
#          speaks — llama.cpp runs the omni Thinker (text out), not the
#          Talker. Needs `brew install llama.cpp`; the first start
#          downloads ~18 GB of weights.
#   1    = attach the utterance audio to the LM Studio endpoint — for when
#          an audio-capable model is loaded there; audio-blind servers
#          just read the transcript. Gets the same audio-native treatment
#          as omni: no reasoning-suppression fields, cooler sampling.
# NOTE: audio parts inflate the context summarizer's size estimate;
# consider a higher explicit CONTEXT_MAX_TOKENS.
LLM_AUDIO_INPUT=0
# OMNI_LLM_MODEL=ggml-org/Qwen3-Omni-30B-A3B-Instruct-GGUF
# OMNI_LLM_BIN=/opt/homebrew/bin/llama-server
# OMNI_LLM_PORT=8033
# OMNI_LLM_CTX=32768
# Sampling for audio-native sessions (omni and =1 alike). Cooler than the
# server default (~0.8): tool discipline on audio turns degrades with
# warmer sampling.
# OMNI_LLM_TEMPERATURE=0.4
# Seconds a session waits for the omni server before falling back to LM Studio
# OMNI_LLM_WAIT_SECS=120

# Voice/typed control commands (matched after wake+speaker gates, on either
# side of "please"/"now" and an optional leading wake word). Voice commands
# are caught server-side and NEVER sent to the LLM. JSON array or comma list.
COMMAND_NEW_SESSION_PHRASES=["start a new session", "start new session"]
COMMAND_MUTE_PHRASES=["shut up", "mute yourself", "be quiet", "i'm not talking to you"]

# --- Speech-to-Text: Qwen3-ASR via mlx-audio ---
QWEN3_ASR_MODEL=mlx-community/Qwen3-ASR-1.7B-8bit
# Pin the ASR language (en, de, ...); empty = auto-detect per utterance
QWEN3_ASR_LANGUAGE=en
# Live partial transcripts while speaking (1 = on; 0 takes load off the GPU)
ASR_INTERIM=1
# Extra vocabulary for ASR context biasing, comma-separated (people-registry
# names and the identity names above are added automatically)
VOICE_VOCABULARY=

# --- Speaker gate: only respond to the enrolled voice ---
# Directory of WAV captures (averaged into one voiceprint) or a single clip;
# empty = respond to anyone. Raise the threshold if others get through;
# lower it if you get ignored.
VOICE_ENROLL_AUDIO=
VOICE_MATCH_THRESHOLD=1.82
# Calibration: 1 = log scores + capture utterances to gate_samples/, drop nothing.
VOICE_GATE_CALIBRATE=0

# --- Turn taking / barge-in ---
# Pause length (seconds) that ends your speaking turn
VAD_STOP_SECS=0.55
# Barge-in sensitivity (how easily you can talk over the bot). Lower = easier.
# Defaults shown; raise them if the bot starts interrupting itself or reacting to noise.
#VAD_START_SECS=0.15
#VAD_CONFIDENCE=0.6
#VAD_MIN_VOLUME=0.3
# Wake gate: from this many seconds after the bot last spoke, an utterance must
# contain one of the wake words in its first 10 words or it is ignored.
# WAKE_WORDS defaults to the agent names above, lowercased.
#WAKE_TIMEOUT_SECS=10
#WAKE_WORDS=serry,serrynaimo

# --- Text-to-Speech: Qwen3-TTS via mlx-audio ---
QWEN3_TTS_MODEL=mlx-community/Qwen3-TTS-12Hz-1.7B-Base-5bit
# Named voice — only for the CustomVoice model variant (vivian, serena, ryan,
# aiden, uncle_fu, dylan, eric, ono_anna, sohee). Leave empty for Base.
QWEN3_TTS_VOICE=
# Voice cloning (Base variant): short ~3-10s clip of the target voice + its
# EXACT transcript. Set both or neither. Design a voice from scratch with
# `uv run design_voice.py` (uses QWEN3_TTS_INSTRUCT below), then pin the
# chosen clip here.
# Defaults to the bundled Serry voice (server/voice_serry.wav). Its transcript:
QWEN3_TTS_REF_AUDIO=voice_serry.wav
QWEN3_TTS_REF_TEXT=Hello! Lovely to meet you. I'm your assistant, and I must say, it's a rather brilliant day for a good conversation.
# Voice character description used by VoiceDesign (design_voice.py)
QWEN3_TTS_INSTRUCT=
# Seconds of audio per streamed chunk: first sentence / follow-up sentences.
# Larger = smoother starts, slower first audio.
QWEN3_TTS_STREAM_INTERVAL=2.8
QWEN3_TTS_STREAM_INTERVAL_CONT=3.6
# Tokens of previous-chunk context carried into each streamed chunk
#QWEN3_TTS_STREAM_CONTEXT=50
# Cooler sampling = steadier, less "frizzly" voice (esp. first seconds)
QWEN3_TTS_TEMPERATURE=0.7
QWEN3_TTS_TOP_K=20
# Speaking tempo, pitch-preserving (1.0 = normal, 1.15 = 15% faster)
QWEN3_TTS_SPEED=1

# --- Web search tool: Google Custom Search ---
# https://developers.google.com/custom-search/v1/overview
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# --- xAI (Grok) Live Search: powers x_search and web_search when set ---
# https://docs.x.ai/developers/tools/x-search — falls back to Google CSE if unset
XAI_API_KEY=
XAI_MODEL=grok-4.5

# --- Financial data tool: Alpha Vantage (stock quotes, fundamentals, FX/crypto) ---
# https://www.alphavantage.co/support/#api-key — free tier: 25 requests/day
ALPHA_VANTAGE_API_KEY=
